APP_NAME=Fresh2U
APP_ENV=local
APP_DEBUG=true
APP_URL=http://127.0.0.1:8080
APP_KEY=change-this-to-a-long-random-secret

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=fresh2u
DB_USER=postgres
DB_PASS=postgres
DB_SCHEMA=public

JWT_ISSUER=fresh2u-api
JWT_TTL_SECONDS=86400

DEFAULT_CURRENCY=CNY
LEADER_CASH_COLLECTION_REQUIRES_REVIEW=true
